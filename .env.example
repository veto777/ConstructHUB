# ConstructHUB environment template
# Copy this file to `.env`, then paste in the real values from
# Replit -> Tools -> Secrets -> "Edit as JSON" (shows all keys + values at once).
# NEVER commit the filled-in .env file to git.

# --- Core ---
DATABASE_URL=            # PostgreSQL connection string
SESSION_SECRET=          # long random string for signing session cookies
PORT=5000
NODE_ENV=development

# --- Google OAuth login + Places ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PLACES_API_KEY=

# --- Google Ads / LSA API (may be empty if not connected yet) ---
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Optional overrides:
# GOOGLE_ADS_API_VERSION=
# LSA_OAUTH_REDIRECT_URI=      # full callback URL for local dev
# LSA_PUBLIC_BASE_URL=         # base origin, defaults to https://constructhub.us

# --- Cloudflare R2 object storage ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_NAME=

# --- Email (Gmail SMTP) ---
SMTP_EMAIL=
SMTP_APP_PASSWORD=
SMTP_EMAIL_BACKUP=
SMTP_APP_PASSWORD_BACKUP=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Frontend publishable key (safe to expose, but keep consistent):
# STRIPE_PUBLISHABLE_KEY=

# --- OpenAI (Replit AI integration on Replit; use your own key locally) ---
AI_INTEGRATIONS_OPENAI_API_KEY=
# AI_INTEGRATIONS_OPENAI_BASE_URL=   # leave empty to use api.openai.com locally

# --- Optional ---
TELEGRAM_BOT_TOKEN=      # only if using LSA Telegram notifications
# CHROMIUM_PATH=         # path to Chromium for the scraper, if needed locally
